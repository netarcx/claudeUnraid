#!/bin/bash
#
# Auto-start Claude Code web terminal when the Unraid array starts
#

CFGFILE="/boot/config/plugins/claude-code/claude-code.cfg"

if [ -f "${CFGFILE}" ]; then
  source "${CFGFILE}"
  if [ "${SERVICE}" = "enable" ]; then
    # Copy Claude binary from flash (noexec) to runtime path
    if [ -f "/boot/config/plugins/claude-code/bin/claude" ]; then
      cp "/boot/config/plugins/claude-code/bin/claude" "/usr/local/bin/claude"
      chmod +x "/usr/local/bin/claude"
    fi
    /etc/rc.d/rc.claude-code start
  fi
fi
