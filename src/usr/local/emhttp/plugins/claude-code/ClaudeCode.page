  </span>
  <?php if ($claude_installed && $claude_version): ?>
    <span style="margin-left: 16px; color: #a9b1d6; font-size: 13px;">
      Claude Code <?=htmlspecialchars($claude_version)?>
    </span>
  <?php elseif (!$claude_installed): ?>
    <span style="margin-left: 16px; color: #f44336; font-size: 13px;">
      Claude Code binary not installed
    </span>
  <?php endif; ?>
