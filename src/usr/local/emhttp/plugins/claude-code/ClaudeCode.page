<div class="claude-actions">
  <?php if ($running): ?>
    <button class="btn-stop" onclick="doAction('stop')">Stop</button>
    <button class="btn-restart" onclick="doAction('restart')">Restart</button>
  <?php else: ?>
    <button class="btn-start" onclick="doAction('start')">Start</button>
  <?php endif; ?>
  <button class="btn-update" onclick="doAction('update')">
    <?=$claude_installed ? 'Update Claude Code' : 'Install Claude Code'?>
  </button>
</div>

<!-- Embedded Terminal -->
<?php if ($running): ?>
<div class="claude-terminal-wrapper">
  <div class="claude-terminal-header">
    <span>Claude Code Terminal</span>
    <a href="<?=htmlspecialchars($terminal_url)?>" target="_blank">Open in new tab &#x2197;</a>
  </div>
  <iframe class="claude-terminal-iframe" src="<?=htmlspecialchars($terminal_url)?>"></iframe>
</div>
<?php else: ?>
