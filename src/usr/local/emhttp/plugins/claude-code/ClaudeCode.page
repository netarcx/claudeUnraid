<?php
$plugin = "claude-code";
$cfg_file = "/boot/config/plugins/{$plugin}/{$plugin}.cfg";
$default_cfg = "/usr/local/emhttp/plugins/{$plugin}/default.cfg";

// Load defaults then user config
$cfg = parse_ini_file($default_cfg) ?: [];
if (file_exists($cfg_file)) {
  $cfg = array_merge($cfg, parse_ini_file($cfg_file) ?: []);
}

$service   = $cfg['SERVICE']   ?? 'disable';
$port      = $cfg['PORT']      ?? '7682';
$workspace = $cfg['WORKSPACE'] ?? '/mnt/user/';
$api_key   = $cfg['API_KEY']   ?? '';

// Get service status
$status = trim(shell_exec("/etc/rc.d/rc.{$plugin} status 2>/dev/null") ?? 'stopped');
$running = ($status === 'running');

// Get server IP/hostname for terminal URL
$server = $_SERVER['HTTP_HOST'] ?? $_SERVER['SERVER_NAME'] ?? 'localhost';
// Strip port from host if present
$server_host = preg_replace('/:\d+$/', '', $server);
$terminal_url = "http://{$server_host}:{$port}";

// Check if Claude binary exists
$claude_installed = file_exists("/boot/config/plugins/{$plugin}/bin/claude");
$claude_version = '';
if ($claude_installed) {
  $claude_version = trim(shell_exec("/boot/config/plugins/{$plugin}/bin/claude --version 2>&1") ?? '');
}
?>

<link type="text/css" rel="stylesheet" href="<?autov('/webGui/styles/jquery.ui.css')?>">
