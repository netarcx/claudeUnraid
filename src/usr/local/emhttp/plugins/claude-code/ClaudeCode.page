          <button type="button" onclick="toggleApiKey()" style="margin-left: 8px; cursor: pointer;">Show/Hide</button>
          <?php if (empty($api_key)): ?>
            <span style="color: #f44336; margin-left: 8px; font-size: 12px;">Required</span>
          <?php endif; ?>
        </td>
      </tr>
      <tr>
        <td>Web Terminal Port:</td>
        <td>
          <input type="number" name="PORT" value="<?=htmlspecialchars($port)?>"
                 min="1024" max="65535" style="width: 100px;">
          <span style="color: #565f89; margin-left: 8px; font-size: 12px;">Default: 7682</span>
        </td>
      </tr>
      <tr>
        <td>Workspace Path:</td>
        <td>
          <input type="text" name="WORKSPACE" value="<?=htmlspecialchars($workspace)?>"
                 style="width: 400px;" placeholder="/mnt/user/">
          <span style="color: #565f89; margin-left: 8px; font-size: 12px;">
            Claude Code will start in this directory
          </span>
        </td>
      </tr>
      <tr>
        <td>Start with Array:</td>
        <td>
          <select name="SERVICE">
            <option value="enable" <?=$service === 'enable' ? 'selected' : ''?>>Yes</option>
            <option value="disable" <?=$service !== 'enable' ? 'selected' : ''?>>No</option>
          </select>
          <span style="color: #565f89; margin-left: 8px; font-size: 12px;">
            Automatically start when the Unraid array starts
          </span>
        </td>
      </tr>
