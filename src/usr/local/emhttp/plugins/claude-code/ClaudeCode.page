  </table>
  <div style="margin-top: 12px;">
    <button type="button" class="btn-start" onclick="saveSettings()"
            style="padding: 8px 24px; font-size: 14px;">Apply</button>
    <button type="button" onclick="resetSettings()"
            style="padding: 8px 24px; font-size: 14px; background: #555; color: #fff; border: none; border-radius: 4px; cursor: pointer; margin-left: 8px;">Reset</button>
  </div>
</form>

<div class="claude-info" style="margin-top: 20px;">
  <strong>Note:</strong> Your API key is stored on the USB flash drive at
  <code>/boot/config/plugins/claude-code/claude-code.cfg</code> and is only accessible to root.
  The Claude Code binary is persisted at
  <code>/boot/config/plugins/claude-code/bin/claude</code> so it survives reboots.
</div>

<script>
function toggleApiKey() {
  var input = document.getElementById('api_key');
  input.type = input.type === 'password' ? 'text' : 'password';
}

function doAction(action) {
  var btns = document.querySelectorAll('.claude-actions button');
  btns.forEach(function(b) { b.disabled = true; b.style.opacity = '0.5'; });

  $.post('/plugins/claude-code/include/exec.php', {action: action}, function(data) {
    setTimeout(function() { location.reload(); }, 2000);
  }).fail(function() {
    alert('Action failed. Check the system log.');
    btns.forEach(function(b) { b.disabled = false; b.style.opacity = '1'; });
  });
}

function saveSettings() {
  var formData = $('#claude-settings').serialize();
  $.post('/plugins/claude-code/include/update.php', formData, function(data) {
    if (data && data.error) {
      alert('Error: ' + data.error);
    } else {
      setTimeout(function() { location.reload(); }, 2000);
    }
  }).fail(function() {
    alert('Failed to save settings.');
  });
}

function resetSettings() {
  if (confirm('Reset all settings to defaults? This will stop the service if running.')) {
    $.post('/plugins/claude-code/include/exec.php', {action: 'stop'}, function() {
      $.post('/plugins/claude-code/include/update.php', {
        SERVICE: 'disable', PORT: '7682', WORKSPACE: '/mnt/user/', API_KEY: ''
      }, function() {
        location.reload();
      });
    });
  }
}
</script>
